{
	"name": "@opentf/immutate",
	"version": "0.1.0",
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@changesets/cli": "^2.31.0",
		"@sylphx/craft": "^1.3.0",
		"immer": "^11.1.4",
		"mutative": "^1.3.0",
		"structurajs": "^0.12.9",
		"tsup": "^8.0.0",
		"typescript": "^6.0.0"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"description": "A lightweight, high-performance immutability library for JavaScript objects.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Open-Tech-Foundation/immutate.git"
	},
	"author": "Open Tech Foundation",
	"license": "MIT",
	"keywords": [
		"immutability",
		"proxy",
		"structural-sharing",
		"performance",
		"immer",
		"mutative"
	],
	"sideEffects": false,
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "tsup --watch",
		"build": "tsup",
		"test": "bun test",
		"benchmark": "bun run bench.ts",
		"prepublishOnly": "bun run build",
		"changeset": "changeset",
		"lint": "biome lint --write .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"ci": "bun run check && bun test && bun run build"
	},
	"type": "module"
}